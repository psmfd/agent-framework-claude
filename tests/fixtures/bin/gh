#!/usr/bin/env bash
# Deterministic gh shim for hook test harnesses — no network, no auth.
# Prepend tests/fixtures/bin to PATH so hooks resolve this instead of real gh.
#
# Controlled via environment variables:
#   FAKE_GH_FAIL=1            every gh invocation fails (network/auth error)
#   FAKE_GH_LOGIN=<name>      output of `gh api user --jq .login`
#   FAKE_GH_ACCESS="o/r o2/r2" space-separated owner/repo list for which
#                             `gh api repos/<owner>/<repo>` succeeds
#
# Targets bash 3.2+ (macOS system bash).

if [ "${FAKE_GH_FAIL:-0}" = "1" ]; then
  echo "fake gh: forced failure" >&2
  exit 1
fi

if [ "${1:-}" = "api" ] && [ "${2:-}" = "user" ]; then
  if [ -z "${FAKE_GH_LOGIN:-}" ]; then
    echo "fake gh: no FAKE_GH_LOGIN configured" >&2
    exit 1
  fi
  printf '%s\n' "$FAKE_GH_LOGIN"
  exit 0
fi

if [ "${1:-}" = "api" ]; then
  case "${2:-}" in
    repos/*)
      repo="${2#repos/}"
      for r in ${FAKE_GH_ACCESS:-}; do
        if [ "$r" = "$repo" ]; then
          exit 0
        fi
      done
      echo "fake gh: no access to $repo" >&2
      exit 1
      ;;
  esac
fi

echo "fake gh: unrecognized invocation: $*" >&2
exit 1
